# ─────────────────────────────────────────────
# TED WITH THE HOUSE – Environment Variables
# Copy this file to .env.local and fill in the values
# ─────────────────────────────────────────────

# Supabase project URL (found in Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous public key (found in Project Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: Supabase service role key (server-side only, never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
